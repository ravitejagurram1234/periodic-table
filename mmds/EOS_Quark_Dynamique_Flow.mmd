flowchart TD
%% ============================================================================
%% EOS Quark Engine - DYNAMIQUE (SQL_DYNAMIQUE) generation flow (start -> end)
%% Exhaustive control flow, every if/else branch, all directions. Java + .NET refs.
%% Render: https://mermaid.live  or  npx -p @mermaid-js/mermaid-cli mmdc -i this.mmd -o out.svg
%% Legend: ([ ]) start/end · [ ] action · {  } decision (yes/no) · dashed "throws" -> CATCH
%% DYNAMIQUE = SQL-driven template repetition with pagination/multi-column + overflow control.
%% DELTA vs Plaquette: ② LOAD loads a separate gabarit_template; ③ PREPARE uploads it;
%%   ④ PROCESS is a 4-stage pipeline (Get/Check/Prepare/Render); ⑥ CHECK may reprocess on overflow.
%% N: Process_Dynamique.cs
%% ============================================================================

    REST(["POST /processRun/{runId}"])
    CTRL["EngineServiceController.processRun → runProcessor"]
    INIT["Create Run · status=TO_GENERATE(1) · startDate=now"]
    REST --> CTRL --> INIT --> START

    subgraph TRY["TRY — main run body"]
    direction TB

      subgraph P1["① START (always)"]
        START["status → RUNNING(4) · runStartUpdateBusiness.execute"]
      end

      subgraph P2["② LOAD (always)  J: load() · N: Run_Base.Load"]
        direction TB
        LP["getRunProperties · prepareGabarit (source switch, upload, degrade, XML+DID)"]
        DLG{"modeDegrade? (load substeps)"}
        LOADREST["getInParams · loadTasks (+DID)"]
        LOADSKIP["skip InParams/Tasks/Templates"]
        %% template loading delta
        LTHAS{"hasDynamicTodo? (a TODO TaskDynamique exists)  N: Run.LoadTemplates"}
        LTSKIP["skip template load"]
        LTID{"idGabaritTemplate == MIN_VALUE (missing)?"}
        LTIDE["RunError(BLOQUANTE 'Manque l'identifiant du gabarit template')"]
        LTFETCH["fetch Gabarit_Template + Load_Templates"]
        LTDEG{"template evaluateModeDegrade? (len>limit)"}
        LTDEGY["modeDegrade=true (gates ③..⑥)"]
        LTOK["templates loaded"]
        LP --> DLG
        DLG -- no --> LOADREST --> LTHAS
        DLG -- yes --> LOADSKIP
        LTHAS -- no --> LTSKIP
        LTHAS -- yes --> LTID
        LTID -- yes --> LTIDE
        LTID -- no --> LTFETCH --> LTDEG
        LTDEG -- yes --> LTDEGY
        LTDEG -- no --> LTOK
      end

      DG{"modeDegrade?  master gate (skips ③..⑥)"}
      LOADREST -.-> DG
      LOADSKIP --> DG
      LTSKIP --> DG
      LTOK --> DG
      LTDEGY --> DG
      LTIDE -.->|throws| CATCH

      %% ----------------- DELTA: PREPARE -----------------
      subgraph P3["③ PREPARE (skipped if degraded)  J: TaskDynamique.prepare"]
        direction TB
        PREPTODO{"task.todo and filePool!=null ?"}
        PREPNULL{"gabaritTemplate == null ?"}
        PREPNULLE["throw IllegalStateException (template must be loaded)"]
        PREPUP["addFile(gabarit_template) to pool"]
        PREPSKIP["skip"]
        PREPTODO -- no --> PREPSKIP
        PREPTODO -- yes --> PREPNULL
        PREPNULL -- yes --> PREPNULLE
        PREPNULL -- no --> PREPUP
      end

      %% ----------------- DELTA: PROCESS (4 stages) -----------------
      subgraph P4["④ PROCESS — DynamiqueTaskProcessStrategy (4 stages)  N: Process_Dynamique.cs"]
        direction TB

        subgraph S1["Stage 1 — Get_Report (SQL → DReport)"]
          direction TB
          S1SQL{"SQL rows non-empty?"}
          S1NONE["log 'No SQL data' · report=null → Stage 4"]
          S1ROW["per row: detect section/group/line/table change"]
          S1TPL{"template in run.getTemplates()?"}
          S1TPLNEW["create new Template(srcName)"]
          S1ABS{"template.isAbsolute()?"}
          S1ABSCELL["DCell → section.cells (absolute)"]
          S1RELCELL["DTable/DRow → DCell (relative)"]
          S1STORE{"storeData and (storeCode & SQL)?"}
          S1STOREY["add DataNameValue (desc/info)"]
          S1MORE{"more rows?"}
          S1SQL -- no --> S1NONE
          S1SQL -- yes --> S1ROW --> S1TPL
          S1TPL -- yes --> S1ABS
          S1TPL -- no --> S1TPLNEW --> S1ABS
          S1ABS -- yes --> S1ABSCELL --> S1STORE
          S1ABS -- no --> S1RELCELL --> S1STORE
          S1STORE -- yes --> S1STOREY --> S1MORE
          S1STORE -- no --> S1MORE
          S1MORE -- yes --> S1ROW
        end

        subgraph S2["Stage 2 — Check_Report (validate TElements)"]
          direction TB
          S2CELL{"per cell: srcName set and element in project?"}
          S2VALID["cell.setTElement (valid)"]
          S2INVALID["cell.setTElement(null) → mark for removal"]
          S2ROW{"row.cells empty after prune?"}
          S2ROWR["remove row"]
          S2TAB{"table.rows empty?"}
          S2TABR["remove table"]
          S2SEC{"section has no cells and no tables?"}
          S2SECR["remove section"]
          S2CELL -- yes --> S2VALID --> S2ROW
          S2CELL -- no --> S2INVALID --> S2ROW
          S2ROW -- yes --> S2ROWR --> S2TAB
          S2ROW -- no --> S2TAB
          S2TAB -- yes --> S2TABR --> S2SEC
          S2TAB -- no --> S2SEC
          S2SEC -- yes --> S2SECR
          S2SEC -- no --> S2DONE["report pruned"]
          S2SECR --> S2DONE
        end

        subgraph S3["Stage 3 — Prepare_Report (geometry/pagination)"]
          direction TB
          S3ANCH{"start and end anchor present and coherent?"}
          S3ANCHE["BLOQUANTE 'Incoherent anchor positions'"]
          S3AVAIL["availableHeight/Width = anchor gap"]
          S3REP{"absoluteRepeat & OTHER_PAGE (0x02)?"}
          S3REPY["add to repeatedCells (clone on new pages)"]
          S3LAST{"absoluteRepeat & LAST_PAGE (0x04)?"}
          S3LASTY["add to lastCells"]
          S3FIRST{"not(hasFirstPage or absRepeat==0)?"}
          S3FIRSTY["remove from first page (deferred)"]
          S3NEWP{"table not first and table.newPage?"}
          S3NEWPY["page++ · reset cursor · addAbsoluteCells"]
          S3BREAK{"row.pageBreak or columnBreak?"}
          S3BREAKY["add to rows2Remove · repeat header on break · downgrade"]
          S3OVF{"tableHeight > availableHeight?"}
          S3COL{"column < nbColumn?"}
          S3COLY["new column (tableWidth += maxWidth + space)"]
          S3PAGE["new page (page++, column=1, addAbsoluteCells)"]
          S3CTRL{"task.controlOverflow?"}
          S3CTRLY["collect all box names → task.boxNames (for ⑥ overflow)"]
          S3ANCH -- "no/incoherent" --> S3ANCHE
          S3ANCH -- yes --> S3AVAIL --> S3REP
          S3REP -- yes --> S3REPY --> S3LAST
          S3REP -- no --> S3LAST
          S3LAST -- yes --> S3LASTY --> S3FIRST
          S3LAST -- no --> S3FIRST
          S3FIRST -- yes --> S3FIRSTY --> S3NEWP
          S3FIRST -- no --> S3NEWP
          S3NEWP -- yes --> S3NEWPY --> S3BREAK
          S3NEWP -- no --> S3BREAK
          S3BREAK -- yes --> S3BREAKY --> S3CTRL
          S3BREAK -- no --> S3OVF
          S3OVF -- yes --> S3COL
          S3OVF -- no --> S3CTRL
          S3COL -- yes --> S3COLY --> S3CTRL
          S3COL -- no --> S3PAGE --> S3CTRL
          S3CTRL -- yes --> S3CTRLY
          S3CTRL -- no --> S3DONE["geometry ready"]
          S3CTRLY --> S3DONE
        end

        subgraph S4["Stage 4 — Render_Boxes (DReport → blocs)"]
          direction TB
          S4NULL{"report == null?"}
          S4ONE["nbNewPage = 1"]
          S4N["nbNewPage = report.info.nbPage"]
          S4PAGES["BlocPage CREATE per new page (name _P{i})"]
          S4REM["BlocPage REMOVE old pages (nbAnciennePage = endPage-startPage +1)"]
          S4ANCH["move start→page0 / end→last · pagination=true → blocsModify"]
          S4CONTENT{"report != null?"}
          S4CELL{"per DCell: getBloc != null?"}
          S4DUP{"name already in blocsModify?"}
          S4DUPW["log WARN duplicate"]
          S4ADD["add BlocBox → blocsModify"]
          S4CELLW["log WARN null bloc"]
          S4MORE{"more cells?"}
          S4NULL -- yes --> S4ONE --> S4PAGES
          S4NULL -- no --> S4N --> S4PAGES
          S4PAGES --> S4REM --> S4ANCH --> S4CONTENT
          S4CONTENT -- no --> S4DONE["render done"]
          S4CONTENT -- yes --> S4CELL
          S4CELL -- yes --> S4DUP
          S4CELL -- no --> S4CELLW --> S4MORE
          S4DUP -- yes --> S4DUPW --> S4MORE
          S4DUP -- no --> S4ADD --> S4MORE
          S4MORE -- yes --> S4CELL
          S4MORE -- no --> S4DONE
        end

        S1NONE --> S4NULL
        S1MORE -- no --> S2CELL
        S2DONE --> S3ANCH
        S3DONE --> S4NULL
        S3ANCHE -.->|throws| CATCH
      end

      %% ----------------- STEPS -----------------
      subgraph P5["⑤ STEPS"]
        direction TB
        DSC{"modeDegrade? (short-circuit)"}
        GETSTEPS["RunTask.getSteps: UPDATE + PAGINATION + MODIFY split@5000<br/>Dynamique = heavy MODIFY + pagination"]
        SLOOP["per step: prepare (evaluateInfo + box limits)"]
        DLIM{"not pagination and nbBoxDoc>nbMaxBoxes?"}
        DLIMEX["exclude boxes (nbBoxExcluded++)"]
        DFULL{"fullExclude?"}
        DDIRECT{"directCall?"}
        HTTP["HTTP combined: ParamsValue + Modify + SaveAs + QxpRender"]
        SOAP["QXPSM SOAP executeStep"]
        POST["download new gabarit → update → inform"]
        SNEXT{"more steps?"}
        DSC -- yes --> SKIPSTEPS["return"]
        DSC -- no --> GETSTEPS --> SLOOP --> DLIM
        DLIM -- yes --> DLIMEX --> DFULL
        DLIM -- no --> DFULL
        DFULL -- yes --> SNEXT
        DFULL -- no --> DDIRECT
        DDIRECT -- "yes (structural)" --> HTTP --> POST
        DDIRECT -- "no (value)" --> SOAP --> POST
        POST --> SNEXT
        SNEXT -- yes --> SLOOP
        SNEXT -- no --> SDONE["steps done"]
      end

      %% ----------------- CHECK (overflow reprocess delta) -----------------
      subgraph P6["⑥ CHECK — overflow reprocess delta  J: CheckServiceImpl"]
        direction TB
        REFRESH["refresh gabarit XML"]
        DOVF{"hasControlOverflow? (TODO Dynamique with controlOverflow)"}
        OVFBOX{"xml.getOverflowBoxes() non-empty?"}
        OVFMATCH["per dynTask: boxNames ∩ overflowBoxes → tasksToReprocess"]
        OVFRE{"tasksToReprocess non-empty?"}
        OVFREY["set others todo=false (except reprocess + allwaysReprocess) → processTasks + steps + refresh XML"]
        DSQL{"store SQL flag?"}
        SQLC["collect SQL data (Dynamique dataNames)"]
        DDOCST{"store DOCUMENT flag?"}
        DOCC2["refresh XML → collect box values (skip Box*/[...])"]
        REFRESH --> DOVF
        DOVF -- yes --> OVFBOX
        DOVF -- no --> DSQL
        OVFBOX -- yes --> OVFMATCH --> OVFRE
        OVFBOX -- no --> DSQL
        OVFRE -- yes --> OVFREY --> DSQL
        OVFRE -- no --> DSQL
        DSQL -- yes --> SQLC --> DDOCST
        DSQL -- no --> DDOCST
        DDOCST -- yes --> DOCC2 --> CDONE["check done"]
        DDOCST -- no --> CDONE
      end

      subgraph P7["⑦ RENDER (always)"]
        direction TB
        DJPG{"renderJpg? (default off)"}
        JPG["JPEG render — propagates"]
        DPDFR{"renderPdf? (default on)"}
        PDFR["PDF render — catch QxpsException swallow; else propagate"]
        DQXPR{"renderQxp? (default on)"}
        QXPF["QXP literal fetch — propagates"]
        BUILD["buildRunResult → finalJpg/finalPdf/finalQxp"]
        SUCCESS["status → GENERATED(2)"]
        DJPG -- yes --> JPG --> DPDFR
        DJPG -- no --> DPDFR
        DPDFR -- yes --> PDFR --> DQXPR
        DPDFR -- no --> DQXPR
        DQXPR -- yes --> QXPF --> BUILD
        DQXPR -- no --> BUILD
        BUILD --> SUCCESS
      end

      %% intra-TRY wiring
      START --> LP
      DG -- "no (normal)" --> PREPTODO
      DG -- "yes (degraded)" --> DJPG
      PREPUP --> S1SQL
      PREPSKIP --> S1SQL
      S4DONE --> DSC
      SDONE --> REFRESH
      SKIPSTEPS --> CDONE
      CDONE --> DJPG
    end

    CATCH["catch (Exception) → status ERROR(3) · RunError(BLOQUANTE)"]
    START -.->|throws| CATCH
    HTTP -.->|throws| CATCH
    SOAP -.->|throws| CATCH
    JPG -.->|throws| CATCH
    QXPF -.->|throws| CATCH
    PREPNULLE -.->|throws| CATCH

    subgraph FIN["FINALLY (always)"]
      direction TB
      FDEG{"modeDegrade?"}
      FDEGE["RunError(CRITIQUE RunInSafeMode)"]
      ERSTART["endRunBusiness.execute · endDate=now"]
      DSTATUS{"status == ERROR?"}
      UPDSTAT["updateStatusRun (no doc insert)"]
      INSDOCS["insert finalQXP(6)+finalPDF(7) → endRun proc"]
      INSERR["insertErrors (blank→'aucun')"]
      AUDIT["insertAuditRun (status label)"]
      DSTORE{"status != ERROR?"}
      DSSQL{"store SQL flag and data?"}
      SSQL["insertData SQL (diff=false)"]
      DSDOC{"store DOC flag and data?"}
      SDOC["insertData DOCUMENT (diff=true)"]
      ERDONE["commit"]
      FDEG -- yes --> FDEGE --> ERSTART
      FDEG -- no --> ERSTART
      ERSTART --> DSTATUS
      DSTATUS -- yes --> UPDSTAT --> INSERR
      DSTATUS -- no --> INSDOCS --> INSERR
      INSERR --> AUDIT --> DSTORE
      DSTORE -- yes --> DSSQL
      DSTORE -- no --> ERDONE
      DSSQL -- yes --> SSQL --> DSDOC
      DSSQL -- no --> DSDOC
      DSDOC -- yes --> SDOC --> ERDONE
      DSDOC -- no --> ERDONE
    end

    SUCCESS --> FDEG
    CATCH --> FDEG
    ERDONE --> RET(["return Run"])

    classDef decision fill:#fff4d6,stroke:#e8a400,color:#5a4500;
    classDef err fill:#fdecec,stroke:#e03131,color:#7a1212;
    classDef ok fill:#e9fbf0,stroke:#0ca678,color:#0a5c43;
    classDef http fill:#e7f1ff,stroke:#1c7ed6,color:#0b4ea2;
    classDef soap fill:#e9fbf0,stroke:#0ca678,color:#0a5c43;
    class DLG,DG,LTHAS,LTID,LTDEG,PREPTODO,PREPNULL,S1SQL,S1TPL,S1ABS,S1STORE,S1MORE,S2CELL,S2ROW,S2TAB,S2SEC,S3ANCH,S3REP,S3LAST,S3FIRST,S3NEWP,S3BREAK,S3OVF,S3COL,S3CTRL,S4NULL,S4CONTENT,S4CELL,S4DUP,S4MORE,DSC,DLIM,DFULL,DDIRECT,SNEXT,DOVF,OVFBOX,OVFRE,DSQL,DDOCST,DJPG,DPDFR,DQXPR,FDEG,DSTATUS,DSTORE,DSSQL,DSDOC decision;
    class LTIDE,PREPNULLE,S3ANCHE,S1NONE,S4DUPW,S4CELLW,CATCH,FDEGE,UPDSTAT,LOADSKIP err;
    class SUCCESS,RET,ERDONE,BUILD,LTOK,S4ADD ok;
    class HTTP http;
    class SOAP soap;
